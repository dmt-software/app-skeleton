{
  "name": "dmt-software/app-skeleton",
  "type": "project",
  "license": "MIT",
  "description": "Create a new application based on Slim framework",
  "keywords": [
    "application",
    "slim",
    "guzzle",
    "pimple",
    "di-plug"
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "authors": [
    {
      "name": "Bas de Mes",
      "email": "bas@dmt-software.nl"
    }
  ],
  "require": {
    "php": ">=8.4",
    "dmt-software/di-plug": "^0.4",
    "doctrine/orm": "^3.6",
    "doctrine/dbal": "^4.4",
    "guzzlehttp/psr7": "^2.0",
    "pimple/pimple": "^3.2",
    "psr/cache": "^3.0",
    "psr/container": "^2.0",
    "psr/http-factory": "^1.1",
    "psr/http-message": "^2.0",
    "psr/http-server-handler": "^1.0",
    "psr/http-server-middleware": "^1.0",
    "psr/log": "^3.0",
    "slim/slim": "^4.2",
    "slim/twig-view": "^3.4",
    "symfony/cache": "^8.0",
    "twig/twig": "^3.23",
    "symfony/event-dispatcher": "^8.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11",
    "squizlabs/php_codesniffer": ">=3.7"
  },
  "autoload": {
    "psr-4": {
      "DMT\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "DMT\\Test\\": "tests/"
    }
  },
  "scripts": {
    "integration": [
      "@phpunit",
      "@run-integration"
    ],
    "phpcs": "phpcs src/ tests/ --standard=PSR12",
    "phpunit": "phpunit",
    "run-integration": "phpunit --group integration",
    "post-create-project-cmd": [
      "echo '# Application\n\ntodo describe the application\n' > README.md"
    ],
    "post-install-cmd": [
      "chmod 0777 cache -R",
      "chmod +x bin/doctrine"
    ]
  }
}
